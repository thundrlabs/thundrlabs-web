---
const email = 'about@thundrlabs.com';
---

<!doctype html>
<html lang="en" style="color-scheme:dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>ThundrLabs</title>
    <meta name="description" content="ThundrLabs — game studio and web lab." />
    <meta property="og:title" content="ThundrLabs" />
    <meta property="og:description" content="Game studio and web lab." />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://thundrlabs.com" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@400;500;600;700&family=Geist+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="stage">
      <div class="wrap">
        <div class="lockup">
          <img
            class="bolt"
            src="/thundrlabs-logo.svg"
            alt=""
            width="82"
            height="120"
          />
          <h1 class="word">Thundr<b>Labs</b><span class="cursor" aria-hidden="true"></span></h1>
        </div>
        <a class="cta" href={`mailto:${email}`}>{email} <span class="arrow" aria-hidden="true">→</span></a>
      </div>
    </main>

    <style>
      *,
      *::before,
      *::after {
        box-sizing: border-box;
      }

      :root {
        --ink: #06070b;
        --lime: #8bd84b;
        --green: #34c24a;
        --green-deep: #0b7d36;
        --pale: #e3fcba;
        --fg: #f4f6f4;
        --muted: #8a9488;
      }

      html,
      body {
        height: 100%;
        margin: 0;
      }

      body {
        font-family: 'Geist', system-ui, sans-serif;
        -webkit-font-smoothing: antialiased;
        background: var(--ink);
        color: var(--fg);
        overflow: hidden;
      }

      .stage {
        position: relative;
        min-height: 100svh;
        display: grid;
        place-items: center;
        isolation: isolate;
        padding: clamp(1.5rem, 5vw, 4rem);
      }

      /* green horizon glow */
      .stage::before {
        content: '';
        position: absolute;
        inset: 0;
        z-index: -2;
        background:
          radial-gradient(120% 80% at 50% -20%, rgba(52, 194, 74, 0.2), transparent 55%),
          radial-gradient(90% 60% at 50% 120%, rgba(139, 216, 75, 0.1), transparent 60%),
          var(--ink);
      }

      /* subtle tech grid */
      .stage::after {
        content: '';
        position: absolute;
        inset: 0;
        z-index: -1;
        opacity: 0.5;
        background-image:
          linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
        background-size: 64px 64px;
        -webkit-mask-image: radial-gradient(75% 60% at 50% 40%, #000 30%, transparent 78%);
        mask-image: radial-gradient(75% 60% at 50% 40%, #000 30%, transparent 78%);
      }

      .wrap {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: clamp(1.8rem, 4vw, 2.6rem);
      }

      .lockup {
        display: flex;
        align-items: center;
        gap: clamp(0.8rem, 2.4vw, 1.5rem);
      }

      .bolt {
        height: clamp(84px, 12vw, 132px);
        width: auto;
        filter: drop-shadow(0 0 22px rgba(139, 216, 75, 0.55))
          drop-shadow(0 0 4px rgba(52, 194, 74, 0.8));
      }

      .word {
        margin: 0;
        font-size: clamp(2.6rem, 9vw, 5.5rem);
        font-weight: 600;
        letter-spacing: -0.03em;
        line-height: 1;
        text-wrap: balance;
      }

      .word b {
        font-weight: 600;
        color: var(--lime);
      }

      .cursor {
        display: inline-block;
        width: 0.09em;
        height: 0.9em;
        margin-left: 0.06em;
        background: var(--lime);
        vertical-align: -0.02em;
        box-shadow: 0 0 12px var(--lime);
        animation: blink 1.1s steps(1) infinite;
      }

      @keyframes blink {
        50% {
          opacity: 0;
        }
      }

      .cta {
        display: inline-flex;
        align-items: center;
        gap: 0.7ch;
        font-family: 'Geist Mono', monospace;
        font-size: 0.98rem;
        letter-spacing: 0.01em;
        color: var(--fg);
        text-decoration: none;
        padding: 0.72rem 1.15rem;
        border-radius: 0.7rem;
        border: 1px solid rgba(139, 216, 75, 0.35);
        background: rgba(52, 194, 74, 0.06);
        transition: transform 0.18s ease;
      }

      .cta:hover,
      .cta:focus-visible {
        border-color: var(--lime);
        background: rgba(52, 194, 74, 0.14);
        color: #fff;
        transform: translateY(-1px);
      }

      .cta .arrow {
        color: var(--lime);
      }

      @media (prefers-reduced-motion: reduce) {
        .cursor {
          animation: none;
        }
        .cta {
          transition: none;
        }
      }
    </style>
  </body>
</html>
